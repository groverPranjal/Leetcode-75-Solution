class Solution {
    public int compress(char[] chars) {
        int i=0;
        int index=0;
        int n=chars.length;
        StringBuilder sb=new StringBuilder();
        while(i<n){
            char c=chars[i];
            int count=0;
            while(i<n && chars[i]==c) {
                count++;
                i++;
            }
            chars[index++]=c;
            if(count>=2){
                for(char ch:String.valueOf(count).toCharArray()) chars[index++]=ch;
            }
        }
        return index;
    }
}
